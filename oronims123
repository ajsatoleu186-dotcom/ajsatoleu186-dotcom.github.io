<!DOCTYPE html>
<html lang="kk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OronymKZ — Trilingual Registry & Map</title>
    <!-- Карта үшін Leaflet CSS қосу -->
    <link rel="stylesheet" href="https://unpkg.com" />
    <style>
        :root { --main: #2c3e50; --gold: #d4af37; --kz: #00afca; --ru: #e74c3c; --en: #2ecc71; }
        body { font-family: 'Helvetica Neue', Arial, sans-serif; margin: 0; background: #f4f4f9; color: #333; line-height: 1.6; }
        
        header { background: var(--main); color: white; padding: 40px 20px; text-align: center; border-bottom: 5px solid var(--gold); }
        .container { max-width: 1100px; margin: 0 auto; padding: 20px; }

        /* Іздеу және Транслитерация бөлімі */
        .search-section { background: white; padding: 25px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin: -40px auto 30px; position: relative; z-index: 1000; }
        input { width: 100%; padding: 15px; border: 2px solid #eee; border-radius: 10px; font-size: 1.1rem; box-sizing: border-box; outline: none; }
        
        .translit-preview { margin-top: 10px; font-size: 0.9rem; color: var(--gold); font-weight: bold; }

        /* Карта стилі */
        #map { height: 400px; width: 100%; border-radius: 20px; margin-bottom: 30px; border: 3px solid white; box-shadow: 0 5px 15px rgba(0,0,0,0.1); z-index: 1; }

        .card { background: white; border-radius: 20px; overflow: hidden; margin-bottom: 50px; box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
        .card-img { width: 100%; height: 300px; background-size: cover; background-position: center; border-bottom: 5px solid var(--gold); }
        
        .card-content { padding: 30px; }
        .trilingual-header { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 15px; margin-bottom: 20px; border-bottom: 2px dashed #eee; padding-bottom: 20px; }
        
        .lang-block { padding: 10px; border-radius: 10px; }
        .qaz-b { border-left: 4px solid var(--kz); background: #f0fbff; }
        .rus-b { border-left: 4px solid var(--ru); background: #fff5f5; }
        .eng-b { border-left: 4px solid var(--en); background: #f5fff8; }

        .label { font-size: 0.7rem; font-weight: bold; text-transform: uppercase; color: #777; display: block; }
        .name { font-size: 1.2rem; font-weight: 800; display: block; }
        .lat-tag { font-style: italic; color: #666; font-size: 0.85rem; }

        .description-section { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
        .desc-text h4 { margin: 0 0 10px; font-size: 0.9rem; color: var(--main); border-bottom: 1px solid #ddd; }
        .desc-text p { font-size: 0.85rem; margin: 0; text-align: justify; }

        @media (max-width: 850px) {
            .trilingual-header, .description-section { grid-template-columns: 1fr; }
            #map { height: 300px; }
        }
    </style>
</head>
<body>

<header>
    <h1>Qazaq Oronyms Registry</h1>
    <p>Интерактивті карта және автоматты транслитерация</p>
</header>

<div class="container">
    <div class="search-section">
        <input type="text" id="searchInput" placeholder="Іздеу / Поиск / Search..." oninput="processSearch()">
        <div class="translit-preview" id="translitOut">Латынша: -</div>
    </div>

    <!-- Интерактивті карта -->
    <div id="map"></div>

    <div id="results"></div>
</div>

<!-- Карта скрипті -->
<script src="https://unpkg.com"></script>

<script>
    // 1. Автоматты транслитерация функциясы (Kaz-Lat)
    function translit(text) {
        const map = {
            'А':'A','Ә':'Ä','Б':'B','В':'V','Г':'G','Ғ':'Ğ','Д':'D','Е':'E','Ё':'E','Ж':'J','З':'Z','И':'I','Й':'I','К':'K','Қ':'Q','Л':'L','М':'M','Н':'N','Ң':'Ñ','О':'O','Ө':'Ö','П':'P','Р':'R','С':'S','Т':'T','У':'U','Ұ':'Ū','Ү':'Ü','Ф':'F','Х':'X','Һ':'H','Ц':'C','Ч':'Ç','Ш':'Ş','Щ':'Ş','Ъ':'','Ы':'Y','І':'İ','Ь':'','Э':'E','Ю':'Iu','Я':'Ia',
            'а':'a','ә':'ä','б':'b','в':'v','г':'g','ғ':'ğ','д':'d','е':'e','ё':'e','ж':'j','з':'z','и':'i','й':'i','к':'k','қ':'q','л':'l','м':'m','н':'n','ң':'ñ','о':'o','ө':'ö','п':'p','р':'r','с':'s','т':'t','у':'u','ұ':'ū','ү':'ü','ф':'f','х':'x','һ':'h','ц':'c','ч':'ç','ш':'ş','щ':'ş','ъ':'','ы':'y','і':'i','ь':'','э':'e','ю':'iu','я':'ia'
        };
        return text.split('').map(char => map[char] || char).join('');
    }

    // 2. Деректер базасы (Координаттарымен)
    const data = [
        {
            coords: [49.80, 86.58],
            img: "https://unsplash.com",
            qaz: { name: "Мұзтау", desc: "Алтайдың ең биік шыңы. Атау мәңгілік мұздарға байланысты." },
            rus: { name: "Белуха", desc: "Высшая точка Алтая. Названа из-за обильного снега." },
            eng: { name: "Mount Belukha", desc: "The highest peak of Altai. Native name means Ice Mountain." }
        },
        {
            coords: [43.08, 77.20],
            img: "https://unsplash.com",
            qaz: { name: "Іле Алатауы", desc: "Тянь-Шань тау жүйесінің солтүстік бөлігі. 'Алатау' — шұбар тау." },
            rus: { name: "Заилийский Алатау", desc: "Хребет на северо-западе Тянь-Шаня, 'за рекой Или'." },
            eng: { name: "Trans-Ili Alatau", desc: "Part of the Northern Tian Shan beyond the Ili River." }
        },
        {
            coords: [53.08, 70.30],
            img: "https://unsplash.com",
            qaz: { name: "Бурабай", desc: "Киелі Бура (түйе) туралы аңызбен байланысты мекен." },
            rus: { name: "Боровое", desc: "Курортная зона, название от соснового бора." },
            eng: { name: "Burabay", desc: "Named after a legend of a sacred camel (Bura)." }
        }
    ];

    // 3. Картаны инициализациялау
    const map = L.map('map').setView([48.0, 66.0], 4);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    let markers = [];

    function processSearch() {
        const val = document.getElementById('searchInput').value;
        document.getElementById('translitOut').innerText = "Латынша: " + translit(val);
        render(val.toLowerCase());
    }

    function render(filter = "") {
        const container = document.getElementById('results');
        container.innerHTML = "";
        markers.forEach(m => map.removeLayer(m));
        markers = [];

        data.forEach(item => {
            if(item.qaz.name.toLowerCase().includes(filter) || item.rus.name.toLowerCase().includes(filter)) {
                // Картаға маркер қосу
                const marker = L.marker(item.coords).addTo(map).bindPopup(item.qaz.name);
                markers.push(marker);

                // Карточканы шығару
                container.innerHTML += `
                    <div class="card">
                        <div class="card-img" style="background-image: url('${item.img}')"></div>
                        <div class="card-content">
                            <div class="trilingual-header">
                                <div class="lang-block qaz-b">
                                    <span class="label">Qazaqsha</span>
                                    <span class="name">${item.qaz.name}</span>
                                    <span class="lat-tag">${translit(item.qaz.name)}</span>
                                </div>
                                <div class="lang-block rus-b">
                                    <span class="label">Русский</span>
                                    <span class="name">${item.rus.name}</span>
                                </div>
                                <div class="lang-block eng-b">
                                    <span class="label">English</span>
                                    <span class="name">${item.eng.name}</span>
                                </div>
                            </div>
                            <div class="description-section">
                                <div class="desc-text"><h4>Тарихы</h4><p>${item.qaz.desc}</p></div>
                                <div class="desc-text"><h4>Значение</h4><p>${item.rus.desc}</p></div>
                                <div class="desc-text"><h4>Meaning</h4><p>${item.eng.desc}</p></div>
                            </div>
                        </div>
                    </div>
                `;
            }
        });
    }

    render();
</script>
</body>
</html>
